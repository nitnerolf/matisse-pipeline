# Minimal git ignore
__pycache__/
*.pyc
.venv/
dist/
build/
*.egg-info/
.ipynb_checkpoints/
.DS_Store
.ruff_cache/
.pyetst_cache/
CODESTYLE_MATISSE.md
# Ignore Iter results from pytest
Iter*/

# Ignore legacy from previous scripts structure
src/matisse/core/legacy/

# Ignore all VS Code config except shared settings.json
.vscode/*
.python-version

# Relative to coverage
.coverage
coverage.xml
htmlcov/

# ignore release files
RELEASING.md
.github/copilot-instructions.md

# Ignore HTML files generated by the viewer
*.html
